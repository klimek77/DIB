SUPABASE_URL=###
SUPABASE_KEY=###
SUPABASE_SERVICE_ROLE_KEY=###
ALLOWED_ADMIN_EMAILS=###
# Sentry: leave empty locally — local dev/tests must stay no-op (see context/changes/sentry-observability/setup.md)
SENTRY_DSN=###
PUBLIC_SENTRY_DSN=###
# Notification email channel (FR-018 alert). Leave empty locally — sendEmail no-ops without both.
# Activates once a sender domain is verified in Resend and both secrets are set (wrangler secret put in prod).
RESEND_API_KEY=###
ALERT_FROM=###
# Absolute app base URL for the weekly-digest dashboard link (no trailing slash, e.g. https://dib.example.com).
# Leave empty locally — the digest just omits the link line. Set in prod (wrangler secret put / var).
APP_BASE_URL=###