---
import BranchChart from "@/components/dashboard/BranchChart.astro";
import DonutRing from "@/components/dashboard/DonutRing.astro";
import SubmissionsList from "@/components/dashboard/SubmissionsList.astro";
import WeeklyChart from "@/components/dashboard/WeeklyChart.astro";
import Layout from "@/layouts/Layout.astro";
import {
  fetchDashboardAggregates,
  fetchSubmissionsList,
  type DashboardAggregates,
  type SubmissionListItem,
} from "@/lib/dashboard/aggregates";
import { donutSegments } from "@/lib/dashboard/donut";
import { resolveRange, type RangePreset } from "@/lib/dashboard/range";
import { createClient } from "@/lib/supabase";
import { BRANCHES, TONES, TOPICS, type Tone, type Topic } from "@/lib/submissions/taxonomies";

// S-02 dashboard (FR-010..FR-013): fully SSR, zero client JS — filters are GET
// links + a native GET form. The page computes no aggregates itself; every
// number comes from src/lib/dashboard/ (RPC + list query), RLS-gated through
// the session-bound SSR client behind the /dashboard middleware guard.

const range = resolveRange(new Date(), Astro.url.searchParams);
const supabase = createClient(Astro.request.headers, Astro.cookies);

let aggregates: DashboardAggregates | null = null;
let items: SubmissionListItem[] = [];
if (supabase) {
  try {
    [aggregates, items] = await Promise.all([
      fetchDashboardAggregates(supabase, range),
      fetchSubmissionsList(supabase, range),
    ]);
  } catch {
    // Error details deliberately not rendered — the retry card below is the
    // whole error surface (design §4.2), never silently-empty data.
    aggregates = null;
  }
}
const loadError = aggregates === null;

const PRESET_LINKS: { preset: Exclude<RangePreset, "custom">; label: string }[] = [
  { preset: "24h", label: "24h" },
  { preset: "7d", label: "Tydzień" },
  { preset: "30d", label: "Miesiąc" },
  { preset: "1y", label: "Rok" },
];

function presetHref(preset: Exclude<RangePreset, "custom">): string {
  const params = new URLSearchParams({ range: preset });
  if (range.branch) params.set("branch", range.branch);
  return `/dashboard?${params.toString()}`;
}

// Pre-fill the custom-range inputs with the active window's Warsaw calendar
// days, so submitting the form with only a branch change keeps the window.
const WARSAW_DAY_FMT = new Intl.DateTimeFormat("en-CA", {
  timeZone: "Europe/Warsaw",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
const fromInputValue = WARSAW_DAY_FMT.format(new Date(range.fromIso));
// toIso is exclusive — step 1 ms back to land on the last included day.
const toInputValue = WARSAW_DAY_FMT.format(new Date(new Date(range.toIso).getTime() - 1));

// KPI accent for the negative-sentiment card (design §4.2 KPICard example).
const negPct = aggregates?.negPct ?? null;
const negAccent = negPct === null ? "#15377B" : negPct > 35 ? "#DB6600" : "#44872E";

// Topic / tone ring colors (design §1.1). The page's only "computation" is
// calling donutSegments on lib data in the frontmatter (SSR) — no client JS.
const TOPIC_COLORS: Record<Topic, string> = {
  Pomysł: "#059669",
  Problem: "#dc2626",
  Usprawnienie: "#2563eb",
  Inne: "#6b7280",
};
const TONE_COLORS: Record<Tone, string> = {
  Pozytywny: "#44872E",
  Negatywny: "#FF0000",
  Neutralny: "#D6D6D6",
};

// Build a ring's SVG segments + legend from a count map. Accepts undefined so
// it stays safe when aggregates failed to load (charts aren't rendered then).
// Topics sum to totalRange (topic is required); tones may sum to less (RPC
// skips ai_tone IS NULL) — donutSegments normalizes to the provided total.
function buildRing<K extends string>(
  counts: Record<K, number> | undefined,
  order: readonly K[],
  colors: Record<K, string>,
) {
  const values = order.map((k) => ({ value: counts?.[k] ?? 0, color: colors[k] }));
  const total = values.reduce((sum, v) => sum + v.value, 0);
  const legend = order.map((k) => {
    const value = counts?.[k] ?? 0;
    return { label: k, value, pct: total === 0 ? 0 : Math.round((100 * value) / total), color: colors[k] };
  });
  return { segments: donutSegments(values), total, legend };
}

const topicRing = buildRing(aggregates?.byTopic, TOPICS, TOPIC_COLORS);
const toneRing = buildRing(aggregates?.byTone, TONES, TONE_COLORS);

const todayLabel = new Date().toLocaleDateString("pl-PL", { dateStyle: "full" });
---

<Layout title="Hub Sugestii — dashboard">
  <div class="font-lato min-h-screen bg-gray-50 text-gray-600">
    {/* TopBar (design §4.2) — the only shadow in the light world. */}
    {/* min-h (not h): on narrow screens the right cluster wraps below the logo. */}
    <header class="bg-sewera-primary flex min-h-14 flex-wrap items-center justify-between gap-2 px-6 py-2 shadow-md">
      <div class="flex items-center gap-3">
        <span class="rounded-md bg-[#005FA3] px-3.5 py-1.5 text-lg font-black tracking-wide text-white">Sewera</span>
        <span class="text-sm text-white/70 max-sm:hidden">Hub Sugestii — dashboard</span>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        {
          /* Branch filter: own GET form with an adjacent submit button, preserving the
            active range via hidden inputs. Zero-JS — no auto-submit-on-change (plan contract). */
        }
        <form method="get" action="/dashboard" class="flex items-center gap-1.5">
          <input type="hidden" name="range" value={range.preset} />
          {
            range.preset === "custom" && (
              <>
                <input type="hidden" name="from" value={fromInputValue} />
                <input type="hidden" name="to" value={toInputValue} />
              </>
            )
          }
          <select
            name="branch"
            aria-label="Oddział"
            class="appearance-none rounded-md border border-white/20 bg-white/[0.12] px-3 py-1.5 text-[13px] text-white"
          >
            <option value="" class="text-gray-700">Wszystkie oddziały</option>
            {
              BRANCHES.map((b) => (
                <option value={b} selected={range.branch === b} class="text-gray-700">
                  {b}
                </option>
              ))
            }
          </select>
          <button
            type="submit"
            class="cursor-pointer rounded-md bg-white/15 px-3 py-1.5 text-[13px] font-semibold text-white transition-colors hover:bg-white/25"
          >
            Filtruj
          </button>
        </form>
        <span class="rounded-md bg-white/15 px-3 py-1.5 text-xs text-white/80">{range.label}</span>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="cursor-pointer rounded-md bg-white/15 px-3 py-1.5 text-xs text-white/80 transition-colors hover:bg-white/25"
          >
            Wyloguj
          </button>
        </form>
      </div>
    </header>

    <main class="mx-auto max-w-[1100px] px-6 py-5 pb-10">
      {/* Time filter bar (FR-010): rolling presets as GET links + custom range form. */}
      <section class="mb-5 flex flex-wrap items-center justify-between gap-3">
        <nav class="flex flex-wrap gap-1.5" aria-label="Zakres czasu">
          {
            PRESET_LINKS.map(({ preset, label }) => (
              <a
                href={presetHref(preset)}
                class:list={[
                  "rounded-md px-3.5 py-1.5 text-[13px] font-semibold transition-colors",
                  range.preset === preset
                    ? "bg-sewera-primary text-white"
                    : "hover:border-sewera-primary hover:text-sewera-primary border border-gray-300 bg-white text-gray-600",
                ]}
                aria-current={range.preset === preset ? "page" : undefined}
              >
                {label}
              </a>
            ))
          }
        </nav>
        <form id="dashboard-filters" method="get" action="/dashboard" class="flex flex-wrap items-center gap-2">
          <input type="hidden" name="range" value="custom" />
          {/* Preserve the active branch when only the date range changes. */}
          {range.branch && <input type="hidden" name="branch" value={range.branch} />}
          <label for="filter-from" class="text-xs font-semibold tracking-wider text-gray-500 uppercase">Od</label>
          <input
            type="date"
            id="filter-from"
            name="from"
            value={fromInputValue}
            class="rounded-md border border-gray-300 bg-white px-2.5 py-1.5 text-[13px] text-gray-700"
          />
          <label for="filter-to" class="text-xs font-semibold tracking-wider text-gray-500 uppercase">Do</label>
          <input
            type="date"
            id="filter-to"
            name="to"
            value={toInputValue}
            class="rounded-md border border-gray-300 bg-white px-2.5 py-1.5 text-[13px] text-gray-700"
          />
          <button
            type="submit"
            class="bg-sewera-primary hover:bg-sewera-cta cursor-pointer rounded-md px-4 py-1.5 text-[13px] font-bold text-white transition-colors"
          >
            Zastosuj
          </button>
        </form>
      </section>

      {
        loadError || !aggregates ? (
          <div class="rounded-lg border border-gray-300 bg-white px-6 py-16 text-center">
            <h1 class="mb-2 text-xl font-bold text-gray-700">Nie udało się pobrać danych</h1>
            <p class="mb-6 text-sm text-gray-500">
              Spróbuj ponownie — jeśli problem się powtarza, sprawdź konfigurację.
            </p>
            <a
              href={Astro.url.pathname + Astro.url.search}
              class="bg-sewera-primary hover:bg-sewera-cta inline-block rounded-md px-6 py-2 text-white transition-colors"
            >
              Spróbuj ponownie
            </a>
          </div>
        ) : (
          <>
            {/* KPI row (design §4.2 KPICard) */}
            <section class="mb-5 flex flex-wrap gap-3">
              <div class="flex min-w-[140px] flex-1 flex-col gap-1 rounded-lg border border-gray-300 bg-white px-4 py-[18px]">
                <span class="text-xs font-semibold tracking-wider text-gray-500 uppercase">Wpisy — wybrany zakres</span>
                <span class="text-sewera-dark text-[32px] leading-tight font-extrabold">{aggregates.totalRange}</span>
                <span class="text-xs text-gray-500">{range.label}</span>
              </div>
              <div class="flex min-w-[140px] flex-1 flex-col gap-1 rounded-lg border border-gray-300 bg-white px-4 py-[18px]">
                <span class="text-xs font-semibold tracking-wider text-gray-500 uppercase">Łącznie od początku</span>
                <span class="text-sewera-dark text-[32px] leading-tight font-extrabold">{aggregates.totalAll}</span>
                <span class="text-xs text-gray-500">
                  {range.branch ? `oddział: ${range.branch}` : "wszystkie oddziały"}
                </span>
              </div>
              <div class="flex min-w-[140px] flex-1 flex-col gap-1 rounded-lg border border-gray-300 bg-white px-4 py-[18px]">
                <span class="text-xs font-semibold tracking-wider text-gray-500 uppercase">Sentyment neg.</span>
                <span class="text-[32px] leading-tight font-extrabold" style={`color:${negAccent}`}>
                  {negPct === null ? "—" : `${negPct}%`}
                </span>
                <span class="text-xs text-gray-500">wpisów negatywnych · AI-generated, może być stronnicze</span>
              </div>
            </section>

            {/* Chart grid (design §4.2) — left: branches + topics donut; right: weekly trend + sentiment ring. */}
            <div class="mb-4 grid grid-cols-[1fr_340px] items-start gap-4 max-lg:grid-cols-1">
              <div class="flex flex-col gap-4">
                <BranchChart byBranch={aggregates.byBranch} activeBranch={range.branch} />
                <DonutRing
                  title="Kategorie wpisów"
                  icon="🏷️"
                  segments={topicRing.segments}
                  centerValue={topicRing.total}
                  centerLabel="wpisów"
                  legend={topicRing.legend}
                />
              </div>
              <div class="flex flex-col gap-4">
                <WeeklyChart byWeek={aggregates.byWeek} />
                <DonutRing
                  title="Sentyment"
                  icon="😊"
                  segments={toneRing.segments}
                  centerValue={toneRing.total}
                  centerLabel="wpisów"
                  legend={toneRing.legend}
                  disclaimer
                />
              </div>
            </div>

            <SubmissionsList items={items} totalRange={aggregates.totalRange} />
          </>
        )
      }

      <footer class="mt-6 flex flex-wrap items-center justify-between gap-2 border-t border-gray-300 pt-3.5">
        <span class="text-[11px] text-gray-500">Hub sugestii pracowniczych · Sewera</span>
        <span class="text-[11px] text-gray-500">{todayLabel}</span>
      </footer>
    </main>
  </div>
</Layout>
