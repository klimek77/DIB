---
import Layout from "@/layouts/Layout.astro";
// Success screen shown after a submission lands (FR-004) — design §4.1 SuccessScreen.
---

<Layout title="Dziękujemy">
  <div
    class="bg-form-world font-dm-sans flex min-h-screen flex-col items-center justify-center px-8 py-16 text-slate-200"
  >
    <div class="animate-in fade-in slide-in-from-bottom-4 mx-auto w-full max-w-[640px] text-center duration-500">
      <!-- Success icon in glow (design §4.1) -->
      <div
        class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-emerald-600 to-emerald-400 text-4xl text-white shadow-[0_0_60px_rgba(5,150,105,0.3)]"
        aria-hidden="true"
      >
        ✓
      </div>

      <h1 class="mb-4 text-[2rem] leading-tight font-semibold text-slate-100">Dziękujemy!</h1>

      <p class="mx-auto mb-10 max-w-[460px] text-base leading-relaxed text-slate-400">
        Twoja sugestia została zapisana anonimowo i trafiła do zespołu. Nie zapisaliśmy żadnych informacji, które
        mogłyby Cię zidentyfikować.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/[0.08] px-8 py-3 text-[0.95rem] font-medium text-slate-200 backdrop-blur-sm transition-all hover:bg-white/[0.14]"
      >
        Wróć na stronę główną
      </a>
    </div>
  </div>
</Layout>
